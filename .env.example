# Environment example — never commit real secrets

APP_ENV=local
RUST_LOG=info,tower_http=info
DATABASE_URL=postgres://dating:dating@127.0.0.1:5432/dating_staging
VALKEY_URL=redis://127.0.0.1:6379
TURN_SHARED_SECRET=CHANGE_ME_LOCAL_ONLY
AGE_ASSURANCE_MODE=mock
ATTESTATION_MODE=mock
PUSH_MODE=mock
SEALED_MAILBOX_ENABLED=false
STAGING_MARKER=true
