{
  "name": "swipe-dating-javascript-rnd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "workspaces": [
    "apps/rnd-*",
    "packages/rnd-*"
  ],
  "scripts": {
    "check:repository-language": "node scripts/check-javascript-only-repository.mjs",
    "check:consolidation": "node scripts/check-javascript-consolidation.mjs",
    "check:syntax": "node scripts/check-javascript-syntax.mjs",
    "check:active-surface": "node scripts/check-active-javascript-surface.mjs",
    "check:unit-tests": "node scripts/check-unit-test-contracts.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "simulate": "node apps/rnd-simulator/src/run.js",
    "api": "node apps/rnd-api/src/server.js",
    "mobile": "npm --workspace @swipe/rnd-mobile run start",
    "mobile:web": "npm --workspace @swipe/rnd-mobile run web",
    "mobile:export:web": "npm --workspace @swipe/rnd-mobile run export:web",
    "production:preflight": "node scripts/production-preflight.mjs",
    "check": "npm run check:repository-language && npm run check:consolidation && npm run check:syntax && npm run check:active-surface && npm run check:unit-tests && npm test && npm run simulate && npm run audit:dependencies",
    "audit:dependencies": "npm audit --audit-level=high"
  }
}
